# ===============================
# 🔐 CARESTACK CREDENTIALS
# ===============================
CARESTACK_BASE_URL=https://YOUR_PRACTICE.carestack.au
CARESTACK_CLIENT_ID=YOUR_CLIENT_ID
CARESTACK_CLIENT_SECRET=YOUR_CLIENT_SECRET
CARESTACK_VENDOR_KEY=YOUR_VENDOR_KEY
CARESTACK_ACCOUNT_KEY=YOUR_ACCOUNT_KEY

# ===============================
# 🔐 GHL (GoHighLevel) CREDENTIALS
# ===============================
GHL_ACCESS_TOKEN=YOUR_GHL_PRIVATE_INTEGRATION_TOKEN

# ===============================
# 🔧 GHL REQUIRED IDS
# Get these from your GHL Sub-Account settings
# ===============================
GHL_LOCATION_ID=YOUR_GHL_LOCATION_ID
GHL_CALENDAR_ID=YOUR_GHL_CALENDAR_ID

# ===============================
# 🔧 SERVER CONFIG
# ===============================
PORT=3000
